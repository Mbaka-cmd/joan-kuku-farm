              "raw": "{\n  \"items\": [\n    {\n      \"product_id\": 1,\n      \"quantity\": 5\n    },\n    {\n      \"product_id\": 2,\n      \"quantity\": 10\n    }\n  ],\n  \"delivery_phone\": \"0712345678\",\n  \"delivery_address\": \"123 Main Street\",\n  \"delivery_city\": \"Nairobi\",\n  \"delivery_county\": \"Nairobi County\",\n  \"delivery_postal_code\": \"00100\",\n  \"delivery_instructions\": \"Please leave at gate\",\n  \"payment_method\": \"mpesa\"\n}"
