        {
          "name": "List Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/products/",
              "host": ["{{base_url}}"],
              "path": ["products", ""],
              "query": [
                {
                  "key": "page",
                  "value": "1",
                  "disabled": true
